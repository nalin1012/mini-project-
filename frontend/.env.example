# ============================================
# AI LEARNING PLATFORM - FRONTEND CONFIGURATION
# ============================================

# ⚠️ IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# DO NOT put secrets in variables with NEXT_PUBLIC_ prefix

# Backend API URL (must start with NEXT_PUBLIC_)
# Local development: http://localhost:8001
# Render production: https://your-backend.onrender.com
# Railway production: https://your-backend-railway.app
NEXT_PUBLIC_API_URL=http://localhost:8001

# Environment (development/staging/production)
NEXT_PUBLIC_ENVIRONMENT=development

# App name (for branding, titles, etc.)
NEXT_PUBLIC_APP_NAME=AI Personalized Learning Platform

# ============================================
# Optional: Analytics & Monitoring
# ============================================
# Google Analytics ID (if using)
# NEXT_PUBLIC_GA_ID=your-google-analytics-id

# ============================================
# Development Server Configuration
# ============================================
# Port for dev server (default: 3000)
# PORT=3000

# ============================================
# Build Optimization
# ============================================
# Next.js telemetry (set to 1 to enable)
# NEXT_TELEMETRY_DISABLED=1

