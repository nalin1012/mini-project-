# ============================================
# AI LEARNING PLATFORM - BACKEND CONFIGURATION
# ============================================

# Environment (development/staging/production)
ENVIRONMENT=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For local development: sqlite:///./learning_platform.db
# For production (PostgreSQL): postgresql://user:password@host:port/dbname
# NOTE: The system automatically converts postgresql:// to postgresql+psycopg:// for SQLAlchemy
DATABASE_URL=sqlite:///./learning_platform.db

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend URL (for redirects, emails, etc.)
FRONTEND_URL=http://localhost:3000

# ============================================
# SECURITY
# ============================================
# Generate a strong random secret for production: 
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-very-secure-random-secret-change-this-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ============================================
# API KEYS & EXTERNAL SERVICES
# ============================================
# Google API Key (for generative AI, etc.)
GOOGLE_API_KEY=your-google-api-key-here

# Firebase Configuration
FIREBASE_DATABASE_URL=your-firebase-database-url
FIREBASE_PROJECT_ID=your-firebase-project-id

# Optional: OpenAI API Key (if using OpenAI)
# OPENAI_API_KEY=your-openai-api-key

# Optional: Gemini API Key (if using Google Gemini)
# GEMINI_API_KEY=your-gemini-api-key

# ============================================
# SERVER CONFIGURATION
# ============================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO


# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ML Model Path
ML_MODEL_PATH=./machine_learning/knowledge_gap_model.pkl
