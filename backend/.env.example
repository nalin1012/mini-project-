# Backend Configuration
DATABASE_URL=sqlite:///./learning_platform.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/dbname

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Google Generative AI Configuration
GOOGLE_API_KEY=your-google-api-key-here

# Firebase Configuration (Optional)
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_CREDENTIALS_JSON=your-firebase-service-account-json-here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ML Model Path
ML_MODEL_PATH=./machine_learning/knowledge_gap_model.pkl
